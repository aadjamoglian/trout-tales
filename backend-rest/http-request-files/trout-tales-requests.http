### Variable for catch to find
@CATCH_ID = 6a4c6e77197725dd3817b273

### Incorrect CATCH_ID does not exist
@NON_EXISTENT_CATCH_ID = 6a258309a07a9729c4905bca

### Create a catch 1
POST http://localhost:3000/catches HTTP/1.1
content-type: application/json

{
    "date": "2026-07-06",
    "species": "brook trout",
    "weight": 1.5,
    "length_in": 12,
    "bait": "Powerbait Pink Mice Tail",
    "story": "Fight of my life, fought him for 10 minutes, almost snapped my line twice.",
    "location": {
        "type": "Point",
        "coordinates": [37.4525, 118.7372] 
    }
}

### Create a catch 2
POST http://localhost:3000/catches HTTP/1.1
content-type: application/json

{
    "date": "2026-07-06",
    "species": "rainbow trout",
    "weight": 2,
    "length_in": 14,
    "bait": "Powerbait Pink Mice Tail",
    "story": "Epic battle dude",
    "location": {
        "type": "Point",
        "coordinates": [37.4525, 118.7372] 
    }
}

